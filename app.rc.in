#include <winres.h>
LANGUAGE 0x09, 0x01

IDI_ICON1 ICON "@CMAKE_CURRENT_SOURCE_DIR@/assets/logo.ico"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904B0"
    BEGIN
      VALUE "CompanyName", "sero583\0"
      VALUE "FileDescription", "CHIP-8 Emulator\0"
      VALUE "FileVersion", "1.0.0\0"
      VALUE "InternalName", "CHIP8_Emulator.exe\0"
      VALUE "OriginalFilename", "CHIP8_Emulator.exe\0"
      VALUE "ProductName", "CHIP-8 Emulator\0"
      VALUE "ProductVersion", "1.0.0\0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x0409, 1200
  END
END